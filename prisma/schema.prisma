// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id             String         @id @default(uuid())
  phone          String         @unique
  key            String?        @unique
  user           TelegramUser? @relation(fields: [userId], references: [id])
  userId         String?
  brand          String?
  // ... existing fields ...
  manufacturer   String?
  model          String?
  board          String?
  hardware       String?
  product        String?
  device         String?
  fingerprint    String?
  release        String?
  sdk            String?
  security_patch String?
  android_id     String?
  correlation_id String?
  device_id      String?
  full_name      String?
  pin_code       String?
  expiresAt      DateTime? 
  isBanned       Boolean        @default(false)
}

model TelegramUser {
  id            String    @id @default(uuid())
  telegramId    String    @unique
  username      String?
  isBanned      Boolean   @default(false)
  isWhitelisted Boolean   @default(false)
  accountLimit  Int       @default(-1)
  createdAt     DateTime  @default(now())
  accounts      Account[]
}
